{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/home-screens/home-screens-plugins/main/schema/manifest-schema.json",
  "title": "Home Screens Plugin Manifest",
  "description": "Schema for a Home Screens plugin's manifest.json file",
  "type": "object",
  "required": [
    "id",
    "name",
    "version",
    "description",
    "author",
    "license",
    "minAppVersion",
    "moduleType",
    "category",
    "icon",
    "defaultConfig",
    "defaultSize",
    "exports"
  ],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique plugin identifier matching the registry entry",
      "pattern": "^[a-z0-9][a-z0-9-]*[a-z0-9]$"
    },
    "name": {
      "type": "string",
      "description": "Human-readable plugin name"
    },
    "version": {
      "type": "string",
      "description": "Semantic version of this plugin build",
      "pattern": "^\\d+\\.\\d+\\.\\d+"
    },
    "description": {
      "type": "string",
      "description": "Short description of what the plugin does"
    },
    "author": {
      "type": "string",
      "description": "Plugin author name or GitHub username"
    },
    "license": {
      "type": "string",
      "description": "SPDX license identifier (e.g. 'MIT', 'Apache-2.0')"
    },
    "minAppVersion": {
      "type": "string",
      "description": "Minimum Home Screens app version required",
      "pattern": "^\\d+\\.\\d+\\.\\d+"
    },
    "moduleType": {
      "type": "string",
      "description": "The module type identifier. The app registers it as plugin:<moduleType>.",
      "pattern": "^[a-z0-9][a-z0-9-]*[a-z0-9]$"
    },
    "category": {
      "$ref": "#/$defs/ModuleCategory"
    },
    "icon": {
      "type": "string",
      "description": "Lucide icon name for the module"
    },
    "defaultConfig": {
      "type": "object",
      "description": "Default configuration values for new instances of this module"
    },
    "defaultSize": {
      "type": "object",
      "required": ["w", "h"],
      "additionalProperties": false,
      "properties": {
        "w": {
          "type": "integer",
          "description": "Default grid width",
          "minimum": 1
        },
        "h": {
          "type": "integer",
          "description": "Default grid height",
          "minimum": 1
        }
      }
    },
    "configSchema": {
      "$ref": "#/$defs/PluginConfigSchema",
      "description": "Optional schema describing the plugin's configurable properties"
    },
    "exports": {
      "type": "object",
      "required": ["component"],
      "additionalProperties": false,
      "properties": {
        "component": {
          "type": "string",
          "description": "Name of the component export (typically 'default')"
        },
        "configSection": {
          "type": "string",
          "description": "Optional named export for the config editor section"
        }
      }
    },
    "dataRequirements": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["location", "weather", "calendar"]
      },
      "uniqueItems": true,
      "description": "Optional list of shared data the plugin needs from the host app"
    },
    "prefetchUrl": {
      "oneOf": [
        { "type": "string", "format": "uri" },
        { "type": "null" }
      ],
      "description": "Optional URL for the app to prefetch data on behalf of the plugin"
    },
    "defaultStyle": {
      "type": "object",
      "description": "Optional partial ModuleStyle overrides applied to new instances",
      "properties": {
        "fontSize": { "type": "number" },
        "fontFamily": { "type": "string" },
        "color": { "type": "string" },
        "textColor": { "type": "string" },
        "backgroundColor": { "type": "string" },
        "borderRadius": { "type": "number" },
        "padding": { "type": "number" },
        "opacity": { "type": "number" },
        "backdropBlur": { "type": "number" }
      },
      "additionalProperties": false
    },
    "secrets": {
      "type": "array",
      "description": "Secrets (API keys, credentials) the plugin requires",
      "items": {
        "type": "object",
        "required": ["key", "label", "required"],
        "additionalProperties": false,
        "properties": {
          "key": { "type": "string", "description": "Secret identifier (e.g. 'api_key')" },
          "label": { "type": "string", "description": "Display name (e.g. 'Spotify API Key')" },
          "description": { "type": "string", "description": "Help text for the user" },
          "required": { "type": "boolean", "description": "Whether the plugin requires this secret to function" },
          "placeholder": { "type": "string", "description": "Input hint" }
        }
      }
    },
    "allowedDomains": {
      "type": "array",
      "description": "Domains the plugin may access via the server-side proxy (e.g. 'api.spotify.com', '*.openweathermap.org')",
      "items": { "type": "string" }
    },
    "permissions": {
      "type": "array",
      "description": "Declared plugin capabilities. Most are transparency-only; 'localNetwork' is runtime-enforced by the proxy.",
      "items": {
        "type": "string",
        "enum": ["network", "localNetwork", "secrets", "events", "storage", "oauth"]
      },
      "uniqueItems": true
    },
    "configMigrations": {
      "type": "object",
      "description": "Maps fromVersion to migration instructions (renames + defaults) for config schema changes between versions",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "renames": {
            "type": "object",
            "description": "Map of old config key → new config key",
            "additionalProperties": { "type": "string" }
          },
          "defaults": {
            "type": "object",
            "description": "Default values for new config keys",
            "additionalProperties": true
          }
        },
        "additionalProperties": false
      }
    },
    "auth": { "$ref": "#/$defs/PluginAuth" },
    "translations": {
      "type": "object",
      "description": "Maps locale codes (e.g. 'en-US') to translation file paths relative to the plugin root",
      "additionalProperties": { "type": "string" }
    }
  },
  "$defs": {
    "PluginAuth": {
      "description": "Server-side auth adapter declaration. The host implements the flow; plugins declare which one they need.",
      "oneOf": [
        { "$ref": "#/$defs/OAuth2Auth" },
        { "$ref": "#/$defs/GarminAuth" }
      ]
    },
    "GarminAuth": {
      "type": "object",
      "required": ["type"],
      "additionalProperties": false,
      "properties": {
        "type": { "const": "garmin" }
      }
    },
    "OAuth2Auth": {
      "type": "object",
      "description": "Declarative OAuth2 configuration covering the three standard grant flows",
      "required": ["type", "flow", "tokenUrl", "scopes", "tokenPlacement", "tokenTargetDomains", "secrets"],
      "additionalProperties": false,
      "properties": {
        "type": { "const": "oauth2" },
        "flow": {
          "type": "string",
          "enum": ["authorization_code", "device_code", "client_credentials"]
        },
        "authorizationUrl": {
          "type": "string",
          "description": "Required for authorization_code and device_code flows"
        },
        "tokenUrl": { "type": "string" },
        "revokeUrl": { "type": "string" },
        "revokeTokenType": {
          "type": "string",
          "enum": ["access_token", "refresh_token"],
          "description": "Defaults to 'access_token'"
        },
        "scopes": {
          "type": "array",
          "items": { "type": "string" }
        },
        "scopeSeparator": {
          "type": "string",
          "description": "Defaults to ' '"
        },
        "pkce": {
          "type": "boolean",
          "description": "Defaults to true for authorization_code"
        },
        "clientAuthentication": {
          "type": "string",
          "enum": ["body", "header", "none"],
          "description": "Defaults to 'body'"
        },
        "tokenPlacement": {
          "type": "string",
          "enum": ["header", "query"]
        },
        "tokenParamName": {
          "type": "string",
          "description": "Required when tokenPlacement is 'query'"
        },
        "tokenTargetDomains": {
          "type": "array",
          "description": "Non-empty subset of allowedDomains that receive the token",
          "items": { "type": "string" },
          "minItems": 1
        },
        "extraAuthParams": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "extraTokenParams": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "tokenResponseTransform": {
          "type": "object",
          "description": "Handle non-standard token responses (dot paths into the response JSON)",
          "additionalProperties": false,
          "properties": {
            "accessTokenPath": { "type": "string" },
            "refreshTokenPath": { "type": "string" },
            "expiresInPath": { "type": "string" },
            "expiresInUnit": { "type": "string", "enum": ["seconds", "milliseconds"] }
          }
        },
        "secrets": {
          "type": "object",
          "required": ["clientId"],
          "additionalProperties": false,
          "properties": {
            "clientId": {
              "type": "string",
              "description": "Key name in plugin secrets[]"
            },
            "clientSecret": {
              "type": "string",
              "description": "Optional for public PKCE clients"
            }
          }
        }
      }
    },
    "ModuleCategory": {
      "type": "string",
      "enum": [
        "Time & Date",
        "Weather & Environment",
        "News & Finance",
        "Knowledge & Fun",
        "Personal",
        "Health & Fitness",
        "Media & Display",
        "Travel"
      ],
      "description": "Module category (must match one of the built-in categories)"
    },
    "PluginConfigSchema": {
      "type": "object",
      "required": ["type", "properties"],
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "const": "object"
        },
        "properties": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/PluginConfigProperty"
          }
        }
      },
      "description": "JSON Schema with ui:widget annotations for declarative config rendering"
    },
    "PluginConfigProperty": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["string", "number", "boolean", "array", "object"],
          "description": "JSON Schema type of this property"
        },
        "title": {
          "type": "string",
          "description": "Human-readable label for the config field"
        },
        "description": {
          "type": "string",
          "description": "Help text shown below the control"
        },
        "default": {
          "description": "Default value for this field"
        },
        "minimum": {
          "type": "number",
          "description": "Minimum value for number fields"
        },
        "maximum": {
          "type": "number",
          "description": "Maximum value for number fields"
        },
        "enum": {
          "type": "array",
          "items": { "type": ["string", "number"] },
          "description": "Allowed values for select widgets"
        },
        "enumLabels": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Display labels corresponding to enum values"
        },
        "ui:widget": {
          "type": "string",
          "enum": ["slider", "toggle", "text", "select", "color", "number", "textarea", "multiselect", "time"],
          "description": "UI widget type for the config renderer"
        },
        "ui:step": {
          "type": "number",
          "description": "Step increment for slider widgets"
        },
        "ui:group": {
          "type": "string",
          "description": "Visual section grouping header"
        },
        "ui:showWhen": {
          "type": "object",
          "required": ["field", "equals"],
          "additionalProperties": false,
          "properties": {
            "field": { "type": "string", "description": "Other config field key" },
            "equals": { "description": "Show this field when field === equals" }
          },
          "description": "Conditional visibility based on another config field's value"
        },
        "ui:placeholder": {
          "type": "string",
          "description": "Input placeholder text"
        },
        "items": {
          "$ref": "#/$defs/PluginConfigProperty",
          "description": "Schema for each array element (when type is 'array')"
        },
        "properties": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/PluginConfigProperty" },
          "description": "Nested properties (when type is 'object')"
        }
      }
    }
  }
}
